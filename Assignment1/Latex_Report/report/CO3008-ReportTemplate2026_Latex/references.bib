@article{Ma2024,
	abstract = {Emotion recognition, which is a crucial aspect of human-computer interaction, involves identifying and analyzing emotional states through observable indicators, especially facial expressions. Building on this concept, the objective of this research is to develop and assess a stacked machine-learning model for emotion recognition based on facial expressions. These models utilize a unique dataset collected from the Vietnamese population. The dataset consists of 3087 images of 441 individuals, with each person expressing seven basic emotions. The performance of the models was meticulously analyzed, with a particular emphasis on the impact of dataset size. Notably, the stacking model incorporating four base models emerged as the superior approach, achieving an accuracy of 84.25% across the entire dataset. This research not only contributes to our understanding of emotion recognition in a diverse cultural context but also advances the application of machine learning techniques in the analysis of facial expressions.},
	author = {Thi Chau Ma and Anh Duc Dam},
	doi = {10.1145/3654522.3654523;JOURNAL:JOURNAL:ACMOTHERCONFERENCES;CTYPE:STRING:BOOK},
	isbn = {9798400716713},
	journal = {ACM International Conference Proceeding Series},
	keywords = {Computer Vision,Emotion Recognition,Facial Expression Analysis,Machine Learning in Emotion Analysis,Stacking,Vietnamese Facial Dataset},
	month = {2},
	pages = {1-6},
	publisher = {Association for Computing Machinery},
	title = {Enhancing Emotion Recognition with Stacked Machine Learning Models: Insights from a Novel Vietnamese Facial Expression Dataset},
	url = {https://dl.acm.org/doi/pdf/10.1145/3654522.3654523},
	year = {2024}
}
@article{Xie2018,
	abstract = {To improve the accuracy of Electroencephalogram (EEG) emotion recognition, a stacking emotion classification model is proposed, in which different classification models such as XGBoost, LightGBM and Random Forest are integrated to learn the features. In addition, the Renyi entropy of 32 channels' EEG signals are extracted as the feature and Linear discriminant analysis (LDA) is employed to reduce the dimension of the feature set. The proposal is tested on the DEAP dataset, and the EEG emotional states are accessed in Arousal-Valence emotion space, in which HA/LA and HV/LV are classified, respectively. The result shows that the average recognition accuracies of 77.19% for HA/LA and 79.06% for HV/LV are obtained, which demonstrates that the proposal is feasible in EEG emotion recognition.},
	author = {Oiao Xie and Zhen Tao Liu and Xue Wen Ding},
	doi = {10.23919/CHICC.2018.8483496},
	isbn = {9789881563941},
	issn = {21612927},
	journal = {Chinese Control Conference, CCC},
	keywords = {Electroencephalogram,Emotion recognition,Renyi entropy,Stacking model},
	month = {10},
	pages = {5544-5548},
	publisher = {IEEE Computer Society},
	title = {Electroencephalogram Emotion Recognition Based on A Stacking Classification Model},
	volume = {2018-July},
	url = {https://ieeexplore.ieee.org/document/8483496},
	year = {2018}
}
@article{Shan2009,
	abstract = {Automatic facial expression analysis is an interesting and challenging problem, and impacts important applications in many areas such as human-computer interaction and data-driven animation. Deriving an effective facial representation from original face images is a vital step for successful facial expression recognition. In this paper, we empirically evaluate facial representation based on statistical local features, Local Binary Patterns, for person-independent facial expression recognition. Different machine learning methods are systematically examined on several databases. Extensive experiments illustrate that LBP features are effective and efficient for facial expression recognition. We further formulate Boosted-LBP to extract the most discriminant LBP features, and the best recognition performance is obtained by using Support Vector Machine classifiers with Boosted-LBP features. Moreover, we investigate LBP features for low-resolution facial expression recognition, which is a critical problem but seldom addressed in the existing work. We observe in our experiments that LBP features perform stably and robustly over a useful range of low resolutions of face images, and yield promising performance in compressed low-resolution video sequences captured in real-world environments. © 2008 Elsevier B.V. All rights reserved.},
	author = {Caifeng Shan and Shaogang Gong and Peter W. McOwan},
	doi = {10.1016/J.IMAVIS.2008.08.005},
	issn = {0262-8856},
	issue = {6},
	journal = {Image and Vision Computing},
	keywords = {Adaboost,Facial expression recognition,Linear discriminant analysis,Linear programming,Local Binary Patterns,Support vector machine},
	month = {5},
	pages = {803-816},
	publisher = {Elsevier},
	title = {Facial expression recognition based on Local Binary Patterns: A comprehensive study},
	volume = {27},
	url = {https://www.sciencedirect.com/science/article/pii/S0262885608001844?casa\_token
	=VHSaaweYLaIAAAAA:bBqHg3sfi9YnSB6ZyKJ8FREOZiO63qUJ\_Q5OH3Qutc2BGvEqz1RVx63
	e7AideGkyCCcAtiPZnA},
	year = {2009}
}
@article{Siam2022,
	abstract = {Emotion recognition is one of the trending research fields. It is involved in several applications. Its most interesting applications include robotic vision and interactive robotic communication. Human emotions can be detected using both speech and visual modalities. Facial expressions can be considered as ideal means for detecting the persons' emotions. This paper presents a real-time approach for implementing emotion detection and deploying it in the robotic vision applications. The proposed approach consists of four phases: preprocessing, key point generation, key point selection and angular encoding, and classification. The main idea is to generate key points using MediaPipe face mesh algorithm, which is based on real-time deep learning. In addition, the generated key points are encoded using a sequence of carefully designed mesh generator and angular encoding modules. Furthermore, feature decomposition is performed using Principal Component Analysis (PCA). This phase is deployed to enhance the accuracy of emotion detection. Finally, the decomposed features are enrolled into a Machine Learning (ML) technique that depends on a Support Vector Machine (SVM), k-Nearest Neighbor (KNN), Naïve Bayes (NB), Logistic Regression (LR), or Random Forest (RF) classifier. Moreover, we deploy a Multilayer Perceptron (MLP) as an efficient deep neural network technique. The presented techniques are evaluated on different datasets with different evaluation metrics. The simulation results reveal that they achieve a superior performance with a human emotion detection accuracy of 97%, which ensures superiority among the efforts in this field.},
	author = {Ali I. Siam and Naglaa F. Soliman and Abeer D. Algarni and Fathi E. Abd El-Samie and Ahmed Sedik},
	doi = {10.1155/2022/8032673},
	issn = {1687-5273},
	issue = {1},
	journal = {Computational Intelligence and Neuroscience},
	month = {1},
	pages = {8032673},
	pmid = {35154306},
	publisher = {John Wiley \& Sons, Ltd},
	title = {Deploying Machine Learning Techniques for Human Emotion Detection},
	volume = {2022},
	url = {https://onlinelibrary.wiley.com/doi/full/10.1155/2022/8032673},
	year = {2022}
}
@article{Sharma2023,
	abstract = {Facial expressions recognition by emotion is a crucial component in many applications. This paper covers the recent trends in human emotion detection. An overview of various facial emotion recognition and its applications are presented. In the literature review, major machine-learning techniques used for facial emotion identification have been explored. Machine learning approaches are compared on the basis of their advantages, disadvantages, and their accuracy. Theoretical analysis of existing approaches shows that the algorithm providing the maximum accuracy should be used for facial emotion recognition. The existing approaches are also suffered from some challenges and those challenges should be addressed and considered for accurately predicting the users' emotional state. The application of emotion detection is also very vast and a few of the major applications are also discussed. Finally, a brief analysis of existing Machine learning approaches and their conclusion is given.},
	author = {Akshita Sharma and Vriddhi Bajaj and Jatin Arora},
	doi = {10.1109/DELCON57910.2023.10127369},
	isbn = {9798350322064},
	journal = {2nd Edition of IEEE Delhi Section Owned Conference, DELCON 2023 - Proceedings},
	keywords = {emotion recognition,expression classification,expression recognition,face detection,facial feature extraction},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	title = {Machine Learning Techniques for Real-Time Emotion Detection from Facial Expressions},
	url = {https://ieeexplore.ieee.org/document/10127369},
	year = {2023}
}
@article{Sun2008,
	abstract = {Network and multimedia is the trend of the development of the modern education technology. The space- time separation of the modern distance education leads to the affection deficiency of the learners. In order to estimate the affective state of the learners in the modern distant education system, the model of distance education system based on affective computing is proposed and realized which took both facial features as input data. A real time facial expression recognition based on support vector machine ( SVM ) algorithm is also applied in the system. After test of the algorithm in the experiment, 100 facial images of 15 learners are randomly selected from database including six basic emotions and neutral as a training set. 265 facial images of 42 persons are used as testing set. The total recognition rate is 84.55%. © 2008 IEEE.},
	author = {Jian Ming Sun and Xue Sheng Pei and Shi Sheng Zhou},
	doi = {10.1109/ICMLC.2008.4621018},
	isbn = {9781424420964},
	journal = {Proceedings of the 7th International Conference on Machine Learning and Cybernetics, ICMLC},
	keywords = {Emotion recognition module,Facial emotion recognition,Modern distant education system,SVM},
	pages = {3545-3548},
	title = {Facial emotion recognition in modern distant education system using SVM},
	volume = {6},
	url = {https://ieeexplore.ieee.org/document/4621018},
	year = {2008}
}
@article{Abdul-Hadi2020,
	abstract = {Human Speech and Facial are the most significant information carriers for human cognitive-communication and recognizing human's identity and emotional status. With the further growth of computer processing capability and the increase of demand for intelligent living, recognition of emotion based on face and speech became the most significant in the applications of Human-Computer Interaction (HCI). In this paper, Human Speech and Facial based emotion recognition technique using a support vector machine (SVM) has been proposed for improving the performance of detection with multi-emotions effectively. The obtained results of the proposed technique show that the average rate of recognition is higher than other recently existing techniques, and the obtained accuracy is 92.88% for facial model and 85.72 % for speech model with low time-consuming.},
	author = {Meaad Hussein Abdul-Hadi and Jumana Waleed},
	doi = {10.1109/CSASE48920.2020.9142065},
	isbn = {9781728152493},
	journal = {Proceedings of the 2020 International Conference on Computer Science and Software Engineering, CSASE 2020},
	keywords = {Human Speech and Facial,emotion recognition technique,histograms of oriented gradients (HOG),support vector machine (SVM)},
	month = {4},
	pages = {191-196},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	title = {Human Speech and Facial Emotion Recognition Technique Using SVM},
	url = {https://ieeexplore.ieee.org/document/9142065},
	year = {2020}
}
@article{Sastriana2024,
	abstract = {Facial Expression Recognition (FER) is critical for applications in security, emotion analysis, and human-computer interactions. This work investigates the usage of a hybrid strategy that combines three feature extraction techniques Discrete Wavelet Transform (DWT), Histogram of Oriented Gradients (HOG), and Local Binary Patterns (LBP) with a Support Vector Machine (SVM) model. The objective is to improve the accuracy and resilience of FER systems by combining predictions from models trained on each feature set. The CK+48 dataset, which contains 22,410 photos across eight emotion classes, serves as the benchmark. The experimental findings reveal that separate feature extraction approaches (DWT, HOG, and LBP) achieve accuracies of 65.62%, 71.88%, and 47.19%, respectively. However, the late fusion model greatly increases performance, obtaining an overall accuracy of 93.44%. The late fusion approach combines the strengths of many characteristics to overcome issues including illumination fluctuations, face expressions, and occlusion. This work demonstrates the potential of late fusion to improve the reliability and accuracy of FER systems in real-world applications.},
	author = {Walid Fernando Sastriana and Simeon Yuda Prasetyo and Eko Setyo Purwanto},
	doi = {10.1109/BTS-I2C63534.2024.10941791},
	isbn = {9798331508579},
	journal = {2024 Beyond Technology Summit on Informatics International Conference, BTS-I2C 2024},
	keywords = {Facial Expression Recognition,Feature Extraction,Late Fusion,Prediction,Support Vector Machine},
	pages = {653-658},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	title = {Late Fusion Approach for Facial Expression Recognition Using HOG, LBP, and DWT Features with SVM},
	url = {https://ieeexplore.ieee.org/document/10941791},
	year = {2024}
}
